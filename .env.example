# Database
DATABASE_URL=

# LLM Provider: "google", "openrouter" or "ollama"
LLM_PROVIDER=

# Google
GOOGLE_API_KEY=
GOOGLE_MODEL=

# OpenRouter
OPENROUTER_API_KEY=

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=  # Your chat ID for ERROR/CRITICAL notifications

# Weather
OPENWEATHER_API_KEY=your_api_key_here
WEATHER_CITY=
WEATHER_COUNTRY=

# General
TIMEZONE=
BOT_MODE=polling

# LLM Timeouts
LLM_MAX_RETRIES=1

# Memory
MEMORY_MAX_MESSAGES=20
MEMORY_SUMMARY_THRESHOLD=15

# Voice
WHISPER_ENABLED=true
WHISPER_MODEL_SIZE=large-v3
WHISPER_UNLOAD_SECONDS=120  # 0 = keep model in memory forever
